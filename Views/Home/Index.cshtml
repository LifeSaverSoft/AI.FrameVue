@{
    ViewData["Title"] = "Frame Your Art";
}

<!-- Upload Section -->
<section id="upload-section" class="section upload-section">
    <div class="section-intro">
        <h1>Frame Your <span class="gold">Masterpiece</span></h1>
        <p class="subtitle">Upload a photo and our AI will create 3 unique custom framing designs using premium vendors</p>
    </div>
    <div id="drop-zone" class="drop-zone">
        <div class="drop-zone-content">
            <div class="upload-icon">
                <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="4" width="56" height="56" rx="6" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" opacity="0.4"/>
                    <rect x="12" y="12" width="40" height="40" rx="3" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
                    <path d="M32 24v16M24 32h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <h3>Drop your image here</h3>
            <p>or <span class="gold">click to browse</span></p>
            <p class="file-hint">Supports JPG, PNG, WebP — up to 20 MB</p>
        </div>
        <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp" hidden />
    </div>
    <div class="vendor-strip">
        <span>Powered by</span>
        <span class="vendor">Larson Juhl</span>
        <span class="vendor-dot"></span>
        <span class="vendor">Crescent</span>
        <span class="vendor-dot"></span>
        <span class="vendor">Bainbridge</span>
        <span class="vendor-dot"></span>
        <span class="vendor">Roma</span>
        <span class="vendor-dot"></span>
        <span class="vendor">International Moulding</span>
    </div>
</section>

<!-- Loading Section -->
<section id="loading-section" class="section loading-section hidden">
    <div class="loading-layout">
        <div class="preview-card">
            <div class="preview-label">Your Image</div>
            <img id="preview-image" alt="Your uploaded image" />
        </div>
        <div class="loading-info">
            <div class="spinner">
                <div class="spinner-frame"></div>
            </div>
            <h2>Crafting your frames<span class="loading-dots"><span>.</span><span>.</span><span>.</span></span></h2>
            <p>Our AI artisan is designing 3 unique framing options using premium mouldings and mats. This usually takes about a minute.</p>
            <div class="progress-steps">
                <div class="step" id="step-1"><span class="step-num">1</span> Classic Elegance</div>
                <div class="step" id="step-2"><span class="step-num">2</span> Modern Gallery</div>
                <div class="step" id="step-3"><span class="step-num">3</span> Artisan Collection</div>
            </div>
        </div>
    </div>
</section>

<!-- Results Section -->
<section id="results-section" class="section results-section hidden">
    <div class="results-header">
        <div>
            <h2>Your Framing Options</h2>
            <p class="subtitle">3 curated designs crafted by AI</p>
        </div>
        <button id="new-upload-btn" class="btn-primary">
            <svg viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            Frame Another Image
        </button>
    </div>
    <div id="results-grid" class="results-grid">
        <!-- Populated by JavaScript -->
    </div>
</section>

<!-- Error Section -->
<section id="error-section" class="section error-section hidden">
    <div class="error-card">
        <div class="error-icon">
            <svg viewBox="0 0 48 48" fill="none" width="48" height="48">
                <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="2"/>
                <path d="M24 14v12M24 30v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </div>
        <h3>Something went wrong</h3>
        <p id="error-message">An unexpected error occurred.</p>
        <button id="retry-btn" class="btn-primary">Try Again</button>
    </div>
</section>
