@{
    ViewData["Title"] = "Frame Your Art";
}

<!-- Mode Selector -->
<section class="mode-selector-section">
    <div class="mode-selector">
        <button class="mode-btn active" onclick="selectMode('upload')" id="mode-upload">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8M8 12h8"/></svg>
            <span>Upload Your Image</span>
        </button>
        <button class="mode-btn" onclick="selectMode('browse')" id="mode-browse">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            <span>Browse Art Prints</span>
        </button>
        <button class="mode-btn" onclick="selectMode('discover')" id="mode-discover">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 3c0 4-4 6-4 9s2 5 4 5 4-2 4-5-4-5-4-9z"/></svg>
            <span>Help Me Find Art</span>
        </button>
        <button class="mode-btn" onclick="selectMode('room')" id="mode-room">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Style My Room</span>
        </button>
        <a href="/Home/Guide" class="mode-btn" style="text-decoration:none; opacity:0.7;" title="User Guide">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><circle cx="12" cy="17" r="0.5" fill="currentColor"/></svg>
            <span>Guide</span>
        </a>
        <a href="/Training" class="mode-btn" style="text-decoration:none; opacity:0.7;" title="Training Admin">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 15l-2 5h4l-2-5z"/><path d="M20 7l-8 5-8-5 8-5 8 5z"/><path d="M20 7v5l-8 5-8-5V7"/></svg>
            <span>Training</span>
        </a>
    </div>
</section>

<!-- Upload Section -->
<section id="upload-section" class="section upload-section">
    <div class="section-intro">
        <h1>Frame Your <span class="gold">Masterpiece</span></h1>
        <p class="subtitle">Upload a photo and our AI will create 3 unique custom framing designs using premium vendors</p>
    </div>
    <div id="drop-zone" class="drop-zone">
        <div class="drop-zone-content">
            <div class="upload-icon">
                <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="4" width="56" height="56" rx="6" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" opacity="0.4"/>
                    <rect x="12" y="12" width="40" height="40" rx="3" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
                    <path d="M32 24v16M24 32h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <h3>Drop your image here</h3>
            <p>or <span class="gold">click to browse</span></p>
            <p class="file-hint">Supports JPG, PNG, WebP — up to 20 MB</p>
        </div>
        <input type="file" id="file-input" accept="image/jpeg,image/png,image/webp" hidden />
    </div>

    <!-- User Context (Optional) -->
    <details class="user-context-panel" id="user-context-panel">
        <summary class="context-toggle">Tell us more about where this will hang <span class="optional-tag">(optional)</span></summary>
        <div class="context-fields">
            <div class="context-row">
                <div class="context-field">
                    <label for="ctx-room">Room Type</label>
                    <select id="ctx-room">
                        <option value="">-- Any --</option>
                        <option value="living room">Living Room</option>
                        <option value="bedroom">Bedroom</option>
                        <option value="office">Office</option>
                        <option value="dining room">Dining Room</option>
                        <option value="hallway">Hallway</option>
                        <option value="gallery">Gallery</option>
                        <option value="commercial">Commercial Space</option>
                    </select>
                </div>
                <div class="context-field">
                    <label for="ctx-wall">Wall Color</label>
                    <input type="text" id="ctx-wall" placeholder="e.g., white, light gray, navy" />
                </div>
            </div>
            <div class="context-row">
                <div class="context-field">
                    <label for="ctx-decor">Decor Style</label>
                    <select id="ctx-decor">
                        <option value="">-- Any --</option>
                        <option value="modern">Modern</option>
                        <option value="traditional">Traditional</option>
                        <option value="rustic">Rustic / Farmhouse</option>
                        <option value="eclectic">Eclectic</option>
                        <option value="minimalist">Minimalist</option>
                        <option value="industrial">Industrial</option>
                        <option value="coastal">Coastal</option>
                    </select>
                </div>
                <div class="context-field">
                    <label for="ctx-purpose">Purpose</label>
                    <select id="ctx-purpose">
                        <option value="">-- Any --</option>
                        <option value="personal display">Personal Display</option>
                        <option value="gift">Gift</option>
                        <option value="commercial sale">Commercial Sale</option>
                        <option value="gallery exhibition">Gallery Exhibition</option>
                    </select>
                </div>
            </div>
            <div class="context-row">
                <div class="context-field">
                    <label for="ctx-lighting">Photo Lighting</label>
                    <select id="ctx-lighting">
                        <option value="">Not Sure (auto-detect)</option>
                        <option value="natural daylight">Natural Daylight</option>
                        <option value="warm incandescent">Warm / Incandescent</option>
                        <option value="cool fluorescent">Cool / Fluorescent</option>
                        <option value="flash">Flash</option>
                        <option value="mixed">Mixed Lighting</option>
                    </select>
                </div>
                <div class="context-field" style="display:flex;align-items:flex-end;">
                    <p style="font-size:0.75rem;color:var(--text-muted);margin:0;">Helps us match colors more accurately when photos are taken under non-neutral lighting.</p>
                </div>
            </div>
        </div>
    </details>

    <div class="vendor-strip">
        <span>Powered by</span>
        <span class="vendor">Larson Juhl</span>
        <span class="vendor-dot"></span>
        <span class="vendor">Crescent</span>
        <span class="vendor-dot"></span>
        <span class="vendor">Bainbridge</span>
        <span class="vendor-dot"></span>
        <span class="vendor">Roma</span>
        <span class="vendor-dot"></span>
        <span class="vendor">International Moulding</span>
    </div>
</section>

<!-- Loading Section -->
<section id="loading-section" class="section loading-section hidden">
    <div class="loading-layout">
        <div class="preview-card">
            <div class="preview-label">Your Image</div>
            <img id="preview-image" alt="Your uploaded image" />
        </div>
        <div class="loading-info">
            <div class="spinner">
                <div class="spinner-frame"></div>
            </div>
            <h2>Analyzing your artwork<span class="loading-dots"><span>.</span><span>.</span><span>.</span></span></h2>
            <p>Our AI is analyzing colors, style, and mood to design 3 perfectly matched framing options.</p>
            <div class="progress-steps">
                <div class="step active" id="step-analysis"><span class="step-num">&#x25C9;</span> Analyzing</div>
                <div class="step" id="step-1"><span class="step-num">1</span> Design 1</div>
                <div class="step" id="step-2"><span class="step-num">2</span> Design 2</div>
                <div class="step" id="step-3"><span class="step-num">3</span> Design 3</div>
            </div>
        </div>
    </div>
</section>

<!-- Results Section -->
<section id="results-section" class="section results-section hidden">
    <div class="results-header">
        <div>
            <h2>Your Framing Options</h2>
            <p class="subtitle">3 curated designs tailored to your artwork</p>
        </div>
        <div class="results-header-actions">
            <button id="compare-btn" class="btn-secondary" disabled onclick="toggleComparisonMode()">
                <svg viewBox="0 0 20 20" fill="none" width="16" height="16"><path d="M4 4h5v12H4zM11 4h5v12h-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Compare
            </button>
            <button id="new-upload-btn" class="btn-primary">
                <svg viewBox="0 0 20 20" fill="none" width="18" height="18"><path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                Frame Another Image
            </button>
        </div>
    </div>
    <div id="compare-selection-bar" class="compare-selection-bar hidden">
        <!-- Populated by JavaScript -->
    </div>
    <div class="provider-label">
        <span class="provider-badge openai-badge">OpenAI</span> gpt-4.1 + image_generation
    </div>
    <div id="results-grid" class="results-grid">
        <!-- Populated by JavaScript -->
    </div>
    <div id="gemini-section" class="gemini-section hidden">
        <div class="provider-label">
            <span class="provider-badge gemini-badge">Gemini</span> gemini-2.5-flash-image
        </div>
        <div id="gemini-results-grid" class="results-grid">
            <!-- Populated by JavaScript -->
        </div>
    </div>
    <div id="leonardo-section" class="leonardo-section hidden">
        <div class="provider-label">
            <span class="provider-badge leonardo-badge">Leonardo</span> FLUX Kontext
        </div>
        <div id="leonardo-results-grid" class="results-grid">
            <!-- Populated by JavaScript -->
        </div>
    </div>
    <div id="stability-section" class="stability-section hidden">
        <div class="provider-label">
            <span class="provider-badge stability-badge">Stability</span> SD 3.5 Large
        </div>
        <div id="stability-results-grid" class="results-grid">
            <!-- Populated by JavaScript -->
        </div>
    </div>
    <div id="comparison-view" class="hidden">
        <!-- Populated by JavaScript -->
    </div>
</section>

<!-- Error Section -->
<section id="error-section" class="section error-section hidden">
    <div class="error-card">
        <div class="error-icon">
            <svg viewBox="0 0 48 48" fill="none" width="48" height="48">
                <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="2"/>
                <path d="M24 14v12M24 30v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </div>
        <h3>Something went wrong</h3>
        <p id="error-message">An unexpected error occurred.</p>
        <button id="retry-btn" class="btn-primary">Try Again</button>
    </div>
</section>

<!-- Browse Art Prints Section -->
<section id="browse-section" class="section browse-section hidden">
    <div class="section-intro">
        <h1>Browse <span class="gold">Art</span></h1>
        <p class="subtitle">Search world-class museum collections. Find the perfect artwork, then frame it with AI.</p>
    </div>

    <div class="browse-source-tabs">
        <button class="source-tab active" id="tab-museum" onclick="switchBrowseSource('museum')">
            <svg viewBox="0 0 20 20" fill="none" width="16" height="16"><path d="M10 2L2 7h16L10 2zM3 8v8h2V8M8 8v8h2V8M13 8v8h2V8M18 8v8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M1 17h18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            Museum Collections
        </button>
        <button class="source-tab" id="tab-catalog" onclick="switchBrowseSource('catalog')">
            <svg viewBox="0 0 20 20" fill="none" width="16" height="16"><rect x="3" y="3" width="14" height="14" rx="2" stroke="currentColor" stroke-width="1.2"/><path d="M7 3v14M3 7h14M3 13h14" stroke="currentColor" stroke-width="1" opacity="0.5"/></svg>
            Our Catalog
        </button>
    </div>

    <!-- Museum Search -->
    <div id="museum-browse" class="browse-content">
        <div class="browse-search-bar">
            <input type="text" id="museum-query" class="search-input" placeholder="Search by title, artist, style, or keyword..." />
            <button class="btn-primary browse-search-btn" onclick="searchMuseumArt(true)">Search</button>
            <button class="btn-secondary browse-filter-toggle" onclick="toggleMuseumFilters()">
                <svg viewBox="0 0 20 20" fill="none" width="16" height="16"><path d="M3 5h14M5 10h10M7 15h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                Filters
            </button>
        </div>
        <div id="museum-filter-panel" class="browse-filter-panel hidden">
            <div class="filter-grid">
                <div class="filter-group">
                    <label>Medium</label>
                    <select id="museum-filter-medium" class="filter-select" onchange="searchMuseumArt(true)">
                        <option value="">All Mediums</option>
                        <option value="Oil">Oil Painting</option>
                        <option value="Watercolor">Watercolor</option>
                        <option value="Acrylic">Acrylic</option>
                        <option value="Pastel">Pastel</option>
                        <option value="Ink">Ink</option>
                        <option value="Pencil">Pencil / Charcoal</option>
                        <option value="Lithograph">Lithograph</option>
                        <option value="Etching">Etching</option>
                        <option value="Woodcut">Woodcut</option>
                        <option value="Photograph">Photograph</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>Classification</label>
                    <select id="museum-filter-classification" class="filter-select" onchange="searchMuseumArt(true)">
                        <option value="">All Types</option>
                        <option value="Painting">Paintings</option>
                        <option value="Print">Prints</option>
                        <option value="Drawing">Drawings</option>
                        <option value="Photograph">Photographs</option>
                        <option value="Poster">Posters</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label>Style</label>
                    <select id="museum-filter-style" class="filter-select" onchange="searchMuseumArt(true)">
                        <option value="">All Styles</option>
                        <option value="Impressionism">Impressionism</option>
                        <option value="Post-Impressionism">Post-Impressionism</option>
                        <option value="Modernism">Modernism</option>
                        <option value="Baroque">Baroque</option>
                        <option value="Renaissance">Renaissance</option>
                        <option value="Abstract">Abstract</option>
                        <option value="Realism">Realism</option>
                        <option value="Romanticism">Romanticism</option>
                        <option value="Art Nouveau">Art Nouveau</option>
                        <option value="Art Deco">Art Deco</option>
                        <option value="Japanese">Japanese</option>
                        <option value="Chinese">Chinese</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="museum-source-note">
            <span class="source-icon">
                <svg viewBox="0 0 16 16" fill="none" width="12" height="12"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M8 5v1M8 8v3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            </span>
            Results from Art Institute of Chicago, Metropolitan Museum of Art &amp; Harvard Art Museums
        </div>
        <div id="museum-info" class="browse-info"></div>
        <div id="museum-prints-grid" class="prints-grid"></div>
        <div id="museum-loading" class="browse-loading hidden">
            <div class="spinner"><div class="spinner-frame"></div></div>
            <span>Searching museum collections...</span>
        </div>
    </div>

    <!-- Catalog Browse (existing local prints) -->
    <div id="catalog-browse" class="browse-content hidden">
        <div class="browse-search-bar">
            <input type="text" id="browse-query" class="search-input" placeholder="Search by title, artist, or keyword..." />
            <button class="btn-primary browse-search-btn" onclick="loadArtPrints(true)">Search</button>
            <button class="btn-secondary browse-filter-toggle" onclick="toggleBrowseFilters()">
                <svg viewBox="0 0 20 20" fill="none" width="16" height="16"><path d="M3 5h14M5 10h10M7 15h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                Filters
            </button>
        </div>
        <div id="browse-filter-panel" class="browse-filter-panel hidden">
            <div class="filter-grid">
                <div class="filter-group">
                    <label>Vendor</label>
                    <div class="combobox-wrap" id="cb-vendor-wrap">
                        <input type="text" id="filter-vendor" class="combobox-input" placeholder="All Vendors" autocomplete="off" />
                        <button class="combobox-clear" type="button">&times;</button>
                        <div class="combobox-dropdown" id="filter-vendor-dropdown"></div>
                    </div>
                </div>
                <div class="filter-group">
                    <label>Artist</label>
                    <div class="combobox-wrap" id="cb-artist-wrap">
                        <input type="text" id="filter-artist" class="combobox-input" placeholder="All Artists" autocomplete="off" />
                        <button class="combobox-clear" type="button">&times;</button>
                        <div class="combobox-dropdown" id="filter-artist-dropdown"></div>
                    </div>
                </div>
                <div class="filter-group">
                    <label>Genre</label>
                    <div class="combobox-wrap" id="cb-genre-wrap">
                        <input type="text" id="filter-genre" class="combobox-input" placeholder="All Genres" autocomplete="off" />
                        <button class="combobox-clear" type="button">&times;</button>
                        <div class="combobox-dropdown" id="filter-genre-dropdown"></div>
                    </div>
                </div>
                <div class="filter-group">
                    <label>Style</label>
                    <div class="combobox-wrap" id="cb-style-wrap">
                        <input type="text" id="filter-style" class="combobox-input" placeholder="All Styles" autocomplete="off" />
                        <button class="combobox-clear" type="button">&times;</button>
                        <div class="combobox-dropdown" id="filter-style-dropdown"></div>
                    </div>
                </div>
                <div class="filter-group">
                    <label>Mood</label>
                    <div class="combobox-wrap" id="cb-mood-wrap">
                        <input type="text" id="filter-mood" class="combobox-input" placeholder="All Moods" autocomplete="off" />
                        <button class="combobox-clear" type="button">&times;</button>
                        <div class="combobox-dropdown" id="filter-mood-dropdown"></div>
                    </div>
                </div>
                <div class="filter-group">
                    <label>Orientation</label>
                    <div class="combobox-wrap" id="cb-orientation-wrap">
                        <input type="text" id="filter-orientation" class="combobox-input" placeholder="All" autocomplete="off" />
                        <button class="combobox-clear" type="button">&times;</button>
                        <div class="combobox-dropdown" id="filter-orientation-dropdown"></div>
                    </div>
                </div>
            </div>
        </div>
        <div id="browse-active-filters" class="filter-chips"></div>
        <div id="browse-info" class="browse-info"></div>
        <div id="browse-prints-grid" class="prints-grid"></div>
        <div id="browse-loading" class="browse-loading hidden">
            <div class="spinner"><div class="spinner-frame"></div></div>
            <span>Loading prints...</span>
        </div>
    </div>
</section>

<!-- AI-Guided Discovery Section -->
<section id="discover-section" class="section discover-section hidden">
    <div class="section-intro">
        <h1>Help Me Find <span class="gold">Art</span></h1>
        <p class="subtitle">Answer a few quick questions and we'll curate art prints just for you.</p>
    </div>

    <!-- Room Photo Shortcut -->
    <div class="discover-step active" id="discover-step-room-photo">
        <h2 class="discover-question">Have a photo of the room?</h2>
        <p class="discover-hint-text">Let AI analyze your room and auto-fill the wizard, or skip to pick manually.</p>
        <div class="discover-room-upload">
            <label for="discover-room-file" class="btn-primary discover-room-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="20" height="20"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Upload Room Photo
            </label>
            <input type="file" id="discover-room-file" accept="image/jpeg,image/png,image/webp" hidden />
            <button class="btn-secondary" onclick="skipDiscoverRoomPhoto()">Skip — I'll pick manually</button>
        </div>
        <div id="discover-room-analyzing" class="discover-room-analyzing hidden">
            <div class="spinner"><div class="spinner-frame"></div></div>
            <span>Analyzing room...</span>
        </div>
    </div>

    <!-- Step 1: Room -->
    <div class="discover-step" id="discover-step-room">
        <h2 class="discover-question">Where will this art live?</h2>
        <div class="discover-options">
            <button class="discover-option" onclick="selectDiscoveryOption('room', this)" data-value="living room">
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="15" width="30" height="15" rx="2"/><path d="M8 15V12a2 2 0 012-2h20a2 2 0 012 2v3"/></svg>
                <span>Living Room</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('room', this)" data-value="bedroom">
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="18" width="30" height="12" rx="2"/><rect x="8" y="12" width="10" height="6" rx="1"/><rect x="22" y="12" width="10" height="6" rx="1"/></svg>
                <span>Bedroom</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('room', this)" data-value="office">
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="8" y="10" width="24" height="16" rx="2"/><path d="M14 26h12v4H14z"/></svg>
                <span>Office</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('room', this)" data-value="dining room">
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="8"/><path d="M20 8v4M20 28v4M8 20h4M28 20h4"/></svg>
                <span>Dining Room</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('room', this)" data-value="hallway">
                <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="10" y="5" width="20" height="30" rx="2"/><circle cx="26" cy="20" r="1.5"/></svg>
                <span>Hallway</span>
            </button>
        </div>
        <button class="discover-skip" onclick="advanceDiscoveryStep('room')">Skip</button>
    </div>

    <!-- Step 2: Mood -->
    <div class="discover-step" id="discover-step-mood">
        <h2 class="discover-question">What feeling do you want?</h2>
        <div class="discover-options">
            <button class="discover-option" onclick="selectDiscoveryOption('mood', this)" data-value="serene">
                <span class="discover-emoji">&#x1f30a;</span><span>Calm & Serene</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('mood', this)" data-value="dramatic">
                <span class="discover-emoji">&#x26a1;</span><span>Bold & Dramatic</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('mood', this)" data-value="joyful">
                <span class="discover-emoji">&#x2600;</span><span>Joyful & Bright</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('mood', this)" data-value="romantic">
                <span class="discover-emoji">&#x1f339;</span><span>Warm & Romantic</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('mood', this)" data-value="contemplative">
                <span class="discover-emoji">&#x1f319;</span><span>Contemplative</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('mood', this)" data-value="energetic">
                <span class="discover-emoji">&#x1f525;</span><span>Energetic</span>
            </button>
        </div>
        <button class="discover-skip" onclick="advanceDiscoveryStep('mood')">Skip</button>
    </div>

    <!-- Step 3: Colors -->
    <div class="discover-step" id="discover-step-colors">
        <h2 class="discover-question">Pick colors you love <span class="discover-hint">(up to 3)</span></h2>
        <div class="discover-color-palette" id="discover-color-palette">
            <!-- Populated by JS -->
        </div>
        <button class="discover-skip" onclick="advanceDiscoveryStep('colors')">Skip</button>
        <button class="btn-primary discover-next" id="colors-next-btn" onclick="advanceDiscoveryStep('colors')" style="display:none;">Next</button>
    </div>

    <!-- Step 4: Style -->
    <div class="discover-step" id="discover-step-style">
        <h2 class="discover-question">What's your style?</h2>
        <div class="discover-options">
            <button class="discover-option" onclick="selectDiscoveryOption('style', this)" data-value="modern">
                <span>Modern</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('style', this)" data-value="traditional">
                <span>Traditional</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('style', this)" data-value="abstract">
                <span>Abstract</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('style', this)" data-value="photographic">
                <span>Photographic</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('style', this)" data-value="impressionist">
                <span>Impressionist</span>
            </button>
            <button class="discover-option" onclick="selectDiscoveryOption('style', this)" data-value="minimalist">
                <span>Minimalist</span>
            </button>
        </div>
        <button class="discover-skip" onclick="advanceDiscoveryStep('style')">Skip</button>
    </div>

    <!-- Step 5: Results -->
    <div class="discover-step" id="discover-step-results">
        <h2 class="discover-question">Art Curated for <span class="gold">You</span></h2>
        <div id="discover-prints-grid" class="prints-grid"></div>
        <div id="discover-loading" class="browse-loading hidden">
            <div class="spinner"><div class="spinner-frame"></div></div>
            <span>Finding art for you...</span>
        </div>
        <div class="discover-results-actions">
            <button class="btn-secondary" onclick="loadDiscoveryResults()">Show More</button>
            <button class="btn-secondary" onclick="restartDiscovery()">Start Over</button>
        </div>
    </div>
</section>

<!-- Room Style Advisor Section -->
<section id="room-section" class="section room-section hidden">
    <div class="section-intro">
        <h1>Style My <span class="gold">Room</span></h1>
        <p class="subtitle">Upload a photo of your room and we'll recommend art and framing that fits your space.</p>
    </div>
    <div id="room-drop-zone" class="drop-zone">
        <div class="drop-zone-content">
            <div class="upload-icon">
                <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M8 24l24-18 24 18v28a4 4 0 01-4 4H12a4 4 0 01-4-4z" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" opacity="0.4"/>
                    <rect x="22" y="32" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5" opacity="0.6"/>
                    <path d="M32 36v8M28 40h8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <h3>Drop your room photo here</h3>
            <p>or <span class="gold">click to browse</span></p>
            <p class="file-hint">Supports JPG, PNG, WebP — up to 20 MB</p>
        </div>
        <input type="file" id="room-file-input" accept="image/jpeg,image/png,image/webp" hidden />
    </div>
    <details class="user-context-panel" id="room-hints-panel">
        <summary class="context-toggle">Tell us about this room <span class="optional-tag">(optional)</span></summary>
        <div class="context-fields">
            <div class="context-row">
                <div class="context-field">
                    <label for="room-hint-type">Room Type</label>
                    <select id="room-hint-type">
                        <option value="">-- AI will detect --</option>
                        <option value="living room">Living Room</option>
                        <option value="bedroom">Bedroom</option>
                        <option value="office">Office</option>
                        <option value="dining room">Dining Room</option>
                        <option value="hallway">Hallway</option>
                        <option value="nursery">Nursery</option>
                    </select>
                </div>
                <div class="context-field">
                    <label for="room-hint-wall">Wall Color</label>
                    <input type="text" id="room-hint-wall" placeholder="e.g., white, light gray" />
                </div>
            </div>
            <div class="context-row">
                <div class="context-field">
                    <label for="room-hint-style">Design Style</label>
                    <select id="room-hint-style">
                        <option value="">-- AI will detect --</option>
                        <option value="modern">Modern</option>
                        <option value="traditional">Traditional</option>
                        <option value="farmhouse">Farmhouse</option>
                        <option value="mid-century">Mid-Century</option>
                        <option value="minimalist">Minimalist</option>
                        <option value="industrial">Industrial</option>
                        <option value="coastal">Coastal</option>
                        <option value="bohemian">Bohemian</option>
                    </select>
                </div>
                <div class="context-field" style="display:flex;align-items:flex-end;">
                    <p style="font-size:0.75rem;color:var(--text-muted);margin:0;">Hints help the AI but are not required — it will detect everything from the photo.</p>
                </div>
            </div>
        </div>
    </details>
</section>

<!-- Room Loading Section -->
<section id="room-loading-section" class="section loading-section hidden">
    <div class="loading-content" style="text-align:center;padding:3rem 1rem;">
        <div class="spinner"><div class="spinner-frame"></div></div>
        <h2>Analyzing your room<span class="loading-dots"><span>.</span><span>.</span><span>.</span></span></h2>
        <p id="room-loading-step">Detecting design style and color palette</p>
    </div>
</section>

<!-- Room Results Section -->
<section id="room-results-section" class="section room-results-section hidden">
    <div class="room-results-header">
        <h2>Your Room's <span class="gold">Style Profile</span></h2>
        <button class="btn-secondary" onclick="resetRoomAdvisor()">Analyze Another Room</button>
    </div>
    <div id="room-analysis-summary" class="room-analysis-summary"></div>
    <div class="room-framing-section">
        <h3>Recommended <span class="gold">Framing Styles</span></h3>
        <div id="room-framing-grid" class="room-framing-grid"></div>
    </div>
    <div class="room-prints-section">
        <h3>Art That Suits <span class="gold">This Room</span></h3>
        <div id="room-prints-grid" class="prints-grid"></div>
        <p id="room-no-prints" class="room-no-prints hidden">No prints matched — try adding more art to the catalog for better results.</p>
    </div>
</section>

<!-- Print Detail Modal -->
<div id="print-detail-modal" class="print-detail-modal hidden" onclick="if(event.target===this)closePrintDetail()">
    <div class="print-detail-panel">
        <button class="print-detail-close" onclick="closePrintDetail()">&times;</button>
        <div class="print-detail-image-wrap">
            <img id="print-detail-image" alt="Art print" />
        </div>
        <div class="print-detail-info">
            <h2 id="print-detail-title"></h2>
            <p id="print-detail-artist" class="print-detail-artist"></p>
            <div id="print-detail-badges" class="print-detail-badges"></div>
            <p id="print-detail-desc" class="print-detail-desc"></p>
            <div class="print-detail-colors" id="print-detail-colors"></div>
            <div class="print-detail-actions">
                <button class="btn-primary" onclick="frameThisPrint()">Frame This Print</button>
                <button class="btn-secondary" onclick="moreLikeThis()">More Like This</button>
                <button class="btn-secondary btn-dismiss" onclick="notLikeThis()">Not This</button>
            </div>
        </div>
    </div>
</div>
