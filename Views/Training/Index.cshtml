@{
    ViewData["Title"] = "Training Admin";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI.FrameVue — Training Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg-primary: #08080f;
            --bg-secondary: #0e0e1a;
            --bg-card: #141422;
            --accent: #c9a84c;
            --accent-light: #d4b96a;
            --text-primary: #e8e8f0;
            --text-secondary: #8888a0;
            --border: #2a2a40;
            --success: #4caf50;
            --danger: #e74c3c;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }

        .header {
            background: var(--bg-secondary);
            border-bottom: 1px solid var(--border);
            padding: 1.5rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.5rem;
            color: var(--accent);
        }

        .header .stats {
            display: flex;
            gap: 1.5rem;
            font-size: 0.85rem;
            color: var(--text-secondary);
        }

        .header .stat-value { color: var(--accent); font-weight: 600; }

        .auth-gate {
            max-width: 400px;
            margin: 4rem auto;
            padding: 2rem;
            text-align: center;
        }

        .auth-gate h2 {
            font-family: 'Playfair Display', serif;
            margin-bottom: 1rem;
            color: var(--accent);
        }

        .auth-gate input {
            width: 100%;
            padding: 0.75rem 1rem;
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-primary);
            font-size: 1rem;
            margin-bottom: 1rem;
        }

        .btn {
            padding: 0.6rem 1.5rem;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn-primary {
            background: var(--accent);
            color: var(--bg-primary);
        }

        .btn-primary:hover { background: var(--accent-light); }

        .btn-danger {
            background: transparent;
            color: var(--danger);
            border: 1px solid var(--danger);
        }

        .btn-danger:hover { background: var(--danger); color: white; }

        .btn-small { padding: 0.4rem 0.8rem; font-size: 0.8rem; }

        .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }

        .tabs {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 2rem;
            border-bottom: 1px solid var(--border);
            padding-bottom: 0.5rem;
        }

        .tab {
            padding: 0.6rem 1.2rem;
            background: transparent;
            border: none;
            color: var(--text-secondary);
            cursor: pointer;
            border-radius: 6px 6px 0 0;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .tab.active { background: var(--bg-card); color: var(--accent); }
        .tab:hover { color: var(--text-primary); }

        .section { display: none; }
        .section.active { display: block; }

        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.5rem;
            margin-bottom: 1rem;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.75rem;
        }

        .card-header h3 { font-size: 1rem; color: var(--accent); }

        .badge {
            font-size: 0.75rem;
            padding: 0.2rem 0.6rem;
            border-radius: 4px;
            background: rgba(201, 168, 76, 0.15);
            color: var(--accent);
        }

        .card p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; margin-bottom: 0.5rem; }

        .examples-list {
            font-size: 0.85rem;
            color: var(--text-secondary);
            padding-left: 1.2rem;
            margin-top: 0.5rem;
        }

        .examples-list li { margin-bottom: 0.3rem; }

        .form-group { margin-bottom: 1rem; }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 0.4rem;
        }

        .form-group input, .form-group select, .form-group textarea {
            width: 100%;
            padding: 0.6rem 0.8rem;
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text-primary);
            font-size: 0.9rem;
            font-family: inherit;
        }

        .form-group textarea { min-height: 80px; resize: vertical; }

        .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

        .add-form {
            background: var(--bg-card);
            border: 1px dashed var(--border);
            border-radius: 10px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .add-form h3 {
            color: var(--accent);
            margin-bottom: 1rem;
            font-family: 'Playfair Display', serif;
        }

        .card-actions { display: flex; gap: 0.5rem; }

        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--success);
            color: white;
            padding: 0.8rem 1.5rem;
            border-radius: 8px;
            font-size: 0.9rem;
            opacity: 0;
            transition: opacity 0.3s;
            z-index: 999;
        }

        .toast.show { opacity: 1; }

        .hidden { display: none !important; }

        .back-link {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.85rem;
        }

        .back-link:hover { color: var(--accent); }

        /* Voice dictation */
        .form-group label {
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .mic-btn {
            width: 26px;
            height: 26px;
            border-radius: 50%;
            border: 1px solid var(--border);
            background: var(--bg-secondary);
            color: var(--text-secondary);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0;
            transition: all 0.2s;
            flex-shrink: 0;
        }

        .mic-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
        }

        .mic-btn svg {
            width: 14px;
            height: 14px;
        }

        .mic-btn.recording {
            background: var(--danger);
            border-color: var(--danger);
            color: white;
            animation: mic-pulse 1.2s ease-in-out infinite;
        }

        @@keyframes mic-pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(231, 76, 60, 0.4); }
            50% { box-shadow: 0 0 0 6px rgba(231, 76, 60, 0); }
        }

        .no-speech-api .mic-btn { display: none; }

        /* Browse catalog */
        .product-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            transition: border-color 0.2s;
        }

        .product-card:hover { border-color: var(--accent); }

        .product-card img {
            width: 100%;
            height: 160px;
            object-fit: cover;
            background: var(--bg-secondary);
        }

        .product-card .card-body { padding: 0.75rem; }
        .product-card .card-body h4 { font-size: 0.85rem; margin-bottom: 0.3rem; color: var(--text-primary); }
        .product-card .card-body p { font-size: 0.75rem; color: var(--text-secondary); margin: 0; line-height: 1.4; }

        .color-swatch {
            display: inline-block;
            width: 14px;
            height: 14px;
            border-radius: 3px;
            border: 1px solid var(--border);
            vertical-align: middle;
            margin-right: 4px;
        }

        .page-btn {
            padding: 0.4rem 0.8rem;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 4px;
            color: var(--text-secondary);
            cursor: pointer;
            font-size: 0.8rem;
        }

        .page-btn:hover { border-color: var(--accent); color: var(--accent); }
        .page-btn.active { background: var(--accent); color: var(--bg-primary); border-color: var(--accent); }

        /* === Combobox === */
        .combobox { position: relative; }
        .combobox input { padding-right: 2rem !important; }
        .combobox-chevron {
            position: absolute;
            right: 0.6rem;
            top: 50%;
            transform: translateY(-50%);
            width: 14px;
            height: 14px;
            color: var(--text-secondary);
            pointer-events: none;
            transition: transform 0.2s;
        }
        .combobox.open .combobox-chevron { transform: translateY(-50%) rotate(180deg); }
        .combobox-dropdown {
            display: none;
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            z-index: 50;
            max-height: 240px;
            overflow-y: auto;
            background: var(--bg-secondary);
            border: 1px solid var(--accent);
            border-top: none;
            border-radius: 0 0 6px 6px;
            list-style: none;
            margin: 0;
            padding: 0;
        }
        .combobox.open .combobox-dropdown { display: block; }
        .combobox-dropdown li {
            padding: 0.45rem 0.8rem;
            font-size: 0.85rem;
            color: var(--text-primary);
            cursor: pointer;
            transition: background 0.15s;
        }
        .combobox-dropdown li:hover,
        .combobox-dropdown li.highlighted {
            background: rgba(201, 168, 76, 0.15);
            color: var(--accent);
        }
        .combobox-dropdown li .match { font-weight: 700; color: var(--accent); }
        .combobox-dropdown::-webkit-scrollbar { width: 6px; }
        .combobox-dropdown::-webkit-scrollbar-track { background: transparent; }
        .combobox-dropdown::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
    </style>
</head>
<body>
    <!-- Auth Gate -->
    <div id="authGate" class="auth-gate">
        <h2>Training Admin</h2>
        <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">
            Enter the admin key to manage the framing knowledge base.
        </p>
        <input type="password" id="adminKeyInput" placeholder="Admin key..." />
        <button class="btn btn-primary" onclick="authenticate()">Enter</button>
        <p id="authError" class="hidden" style="color: var(--danger); margin-top: 1rem;"></p>
    </div>

    <!-- Main Admin UI (hidden until authenticated) -->
    <div id="adminUI" class="hidden">
        <div class="header">
            <div>
                <h1>AI.FrameVue Training Admin</h1>
                <a href="/" class="back-link">Back to app</a>
            </div>
            <div class="stats">
                <span>Rules: <span class="stat-value" id="statRules">0</span></span>
                <span>Style Guides: <span class="stat-value" id="statGuides">0</span></span>
                <span>Examples: <span class="stat-value" id="statExamples">0</span></span>
                <span>Vendors: <span class="stat-value" id="statVendors">0</span></span>
                <span>|</span>
                <span>Catalog Mouldings: <span class="stat-value" id="statCatMouldings">0</span></span>
                <span>Catalog Mats: <span class="stat-value" id="statCatMats">0</span></span>
                <span>|</span>
                <span>Art Prints: <span class="stat-value" id="statArtPrints">0</span></span>
            </div>
        </div>

        <div class="container">
            <div class="tabs">
                <button class="tab active" onclick="showTab('rules')">Framing Rules</button>
                <button class="tab" onclick="showTab('guides')">Style Guides</button>
                <button class="tab" onclick="showTab('examples')">Training Examples</button>
                <button class="tab" onclick="showTab('catalog')">Vendor Catalog</button>
                <button class="tab" onclick="showTab('artprints')">Art Prints</button>
            </div>

            <!-- === FRAMING RULES === -->
            <div id="rulesSection" class="section active">
                <div class="add-form">
                    <h3>Add New Rule</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Category</label>
                            <select id="ruleCategory">
                                <option value="mat-selection">Mat Selection</option>
                                <option value="moulding-selection">Moulding Selection</option>
                                <option value="moulding-width">Moulding Width</option>
                                <option value="color-pairing">Color Pairing</option>
                                <option value="double-mat-rules">Double Mat Rules</option>
                                <option value="style-matching">Style Matching</option>
                                <option value="conservation">Conservation</option>
                                <option value="do-not-do">Do Not Do</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Confidence</label>
                            <select id="ruleConfidence">
                                <option value="high">High</option>
                                <option value="medium">Medium</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Principle (the expert rule) <button type="button" class="mic-btn" onclick="toggleRecording('rulePrinciple')" id="mic-rulePrinciple" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <textarea id="rulePrinciple" placeholder="e.g., Never use bright white mats with warm watercolor paintings..."></textarea>
                    </div>
                    <div class="form-group">
                        <label>Example (one practical example) <button type="button" class="mic-btn" onclick="toggleRecording('ruleExample')" id="mic-ruleExample" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <input type="text" id="ruleExample" placeholder="e.g., Warm sunset painting -> use cream mat, not white" />
                    </div>
                    <div class="form-group">
                        <label>Added By <button type="button" class="mic-btn" onclick="toggleRecording('ruleAddedBy')" id="mic-ruleAddedBy" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <input type="text" id="ruleAddedBy" placeholder="e.g., Jane Smith, CPF" />
                    </div>
                    <button class="btn btn-primary" onclick="addRule()">Add Rule</button>
                </div>
                <div id="rulesList"></div>
            </div>

            <!-- === STYLE GUIDES === -->
            <div id="guidesSection" class="section">
                <div class="add-form">
                    <h3>Add New Style Guide</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Art Style (e.g., oil-painting-classical) <button type="button" class="mic-btn" onclick="toggleRecording('guideArtStyle')" id="mic-guideArtStyle" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                            <input type="text" id="guideArtStyle" placeholder="art-style-name" />
                        </div>
                        <div class="form-group">
                            <label>Keywords (comma-separated) <button type="button" class="mic-btn" onclick="toggleRecording('guideKeywords')" id="mic-guideKeywords" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                            <input type="text" id="guideKeywords" placeholder="oil, classical, renaissance" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Preferred Mouldings (comma-separated) <button type="button" class="mic-btn" onclick="toggleRecording('guidePreferred')" id="mic-guidePreferred" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <input type="text" id="guidePreferred" placeholder="ornate gold, warm wood, antiqued finish" />
                    </div>
                    <div class="form-group">
                        <label>Avoid Mouldings (comma-separated) <button type="button" class="mic-btn" onclick="toggleRecording('guideAvoid')" id="mic-guideAvoid" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <input type="text" id="guideAvoid" placeholder="thin modern metal, bright chrome" />
                    </div>
                    <div class="form-group">
                        <label>Mat Guidance <button type="button" class="mic-btn" onclick="toggleRecording('guideMatGuidance')" id="mic-guideMatGuidance" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <textarea id="guideMatGuidance" placeholder="Describe ideal mat choices for this art style..."></textarea>
                    </div>
                    <div class="form-group">
                        <label>Width Guidance <button type="button" class="mic-btn" onclick="toggleRecording('guideWidthGuidance')" id="mic-guideWidthGuidance" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <input type="text" id="guideWidthGuidance" placeholder="e.g., Medium to wide — classical art needs presence" />
                    </div>
                    <div class="form-group">
                        <label>Notes <button type="button" class="mic-btn" onclick="toggleRecording('guideNotes')" id="mic-guideNotes" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <textarea id="guideNotes" placeholder="Any additional expert notes..."></textarea>
                    </div>
                    <button class="btn btn-primary" onclick="addStyleGuide()">Add Style Guide</button>
                </div>
                <div id="guidesList"></div>
            </div>

            <!-- === TRAINING EXAMPLES === -->
            <div id="examplesSection" class="section">
                <div class="add-form">
                    <h3>Add Training Example</h3>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Description <button type="button" class="mic-btn" onclick="toggleRecording('exDescription')" id="mic-exDescription" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                            <input type="text" id="exDescription" placeholder="e.g., Watercolor landscape with blues and greens" />
                        </div>
                        <div class="form-group">
                            <label>Art Style <button type="button" class="mic-btn" onclick="toggleRecording('exArtStyle')" id="mic-exArtStyle" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                            <input type="text" id="exArtStyle" placeholder="e.g., watercolor" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Medium <button type="button" class="mic-btn" onclick="toggleRecording('exMedium')" id="mic-exMedium" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                            <input type="text" id="exMedium" placeholder="e.g., watercolor" />
                        </div>
                        <div class="form-group">
                            <label>Subject Matter <button type="button" class="mic-btn" onclick="toggleRecording('exSubject')" id="mic-exSubject" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                            <input type="text" id="exSubject" placeholder="e.g., landscape" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Mood <button type="button" class="mic-btn" onclick="toggleRecording('exMood')" id="mic-exMood" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                            <input type="text" id="exMood" placeholder="e.g., serene" />
                        </div>
                        <div class="form-group">
                            <label>Color Temperature</label>
                            <select id="exColorTemp">
                                <option value="warm">Warm</option>
                                <option value="cool">Cool</option>
                                <option value="mixed">Mixed</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Expert Moulding Choice <button type="button" class="mic-btn" onclick="toggleRecording('exMoulding')" id="mic-exMoulding" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <input type="text" id="exMoulding" placeholder="e.g., Natural maple, thin profile (1 inch)" />
                    </div>
                    <div class="form-group">
                        <label>Expert Mat Choice <button type="button" class="mic-btn" onclick="toggleRecording('exMat')" id="mic-exMat" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <input type="text" id="exMat" placeholder="e.g., Single mat, warm white" />
                    </div>
                    <div class="form-group">
                        <label>Reasoning (why these choices work) <button type="button" class="mic-btn" onclick="toggleRecording('exReasoning')" id="mic-exReasoning" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <textarea id="exReasoning" placeholder="Explain the expert reasoning behind these choices..."></textarea>
                    </div>
                    <div class="form-group">
                        <label>Common Mistakes (one per line) <button type="button" class="mic-btn" onclick="toggleRecording('exMistakes')" id="mic-exMistakes" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <textarea id="exMistakes" placeholder="Using bright white mat — kills warmth&#10;Heavy ornate frame — overwhelms watercolor"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Added By <button type="button" class="mic-btn" onclick="toggleRecording('exAddedBy')" id="mic-exAddedBy" title="Dictate"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg></button></label>
                        <input type="text" id="exAddedBy" placeholder="e.g., Mike Chen, Master Framer" />
                    </div>
                    <button class="btn btn-primary" onclick="addExample()">Add Example</button>
                </div>
                <div id="examplesList"></div>
            </div>
            <!-- === VENDOR CATALOG === -->
            <div id="catalogSection" class="section">
                <div class="add-form">
                    <h3>Import Catalog from SQL Server</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.85rem;">
                        Imports vendors, mouldings, and mats from LifeSaver SQL Server into the local SQLite database.
                        This replaces all existing catalog data.
                    </p>
                    <div class="form-group" id="connStrGroup">
                        <label>SQL Server Connection String</label>
                        <div id="connStrSaved" class="hidden" style="display:none; align-items:center; gap:0.75rem; margin-bottom:0.5rem;">
                            <span style="color:var(--success); font-size:0.85rem;" id="connStrDisplay">Saved connection configured</span>
                            <button class="btn btn-small" style="background:var(--bg-secondary); color:var(--text-secondary); border:1px solid var(--border);" onclick="showConnStrField()">Change</button>
                        </div>
                        <input type="text" id="catalogConnStr" placeholder="Server=myserver;Database=LifeSaverVendor;User Id=user;Password=pass;TrustServerCertificate=True;" />
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>S3 Base URL</label>
                            <input type="text" id="catalogS3Base" value="https://lifesaversoft.s3.amazonaws.com" />
                        </div>
                        <div class="form-group">
                            <label>S3 Image Extension</label>
                            <input type="text" id="catalogS3Ext" value=".jpg" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>S3 Moulding Image Path</label>
                            <input type="text" id="catalogS3MouldingPath" value="Moulding Images" />
                        </div>
                        <div class="form-group">
                            <label>S3 Mat Image Path</label>
                            <input type="text" id="catalogS3MatPath" value="Mat Images" />
                        </div>
                    </div>
                    <button class="btn btn-primary" id="importCatalogBtn" onclick="importCatalog()">Import Catalog</button>
                    <span id="importStatus" style="margin-left: 1rem; font-size: 0.85rem; color: var(--text-secondary);"></span>
                </div>

                <!-- Enrichment -->
                <div class="add-form" style="margin-top: 1.5rem;">
                    <h3>AI Color Enrichment</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.85rem;">
                        Downloads each product image from S3 and uses AI vision to analyze colors, finish type, and temperature.
                        ~$0.003 per image with GPT-4o-mini.
                    </p>
                    <div id="enrichProgress" style="margin-bottom: 1rem;">
                        <div style="display:flex; gap:2rem; font-size:0.85rem; color:var(--text-secondary); margin-bottom:0.5rem;">
                            <span>Mouldings: <span class="stat-value" id="enrichMouldingsDone">0</span> / <span id="enrichMouldingsTotal">0</span></span>
                            <span>Mats: <span class="stat-value" id="enrichMatsDone">0</span> / <span id="enrichMatsTotal">0</span></span>
                        </div>
                        <div style="background:var(--bg-secondary); border-radius:4px; height:8px; overflow:hidden;">
                            <div id="enrichBar" style="background:var(--accent); height:100%; width:0%; transition:width 0.3s;"></div>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Batch Size</label>
                            <input type="number" id="enrichBatchSize" value="50" min="1" max="500" />
                        </div>
                        <div class="form-group">
                            <label>Vendor Filter (optional)</label>
                            <input type="text" id="enrichVendorFilter" placeholder="e.g., Larson Juhl" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Type</label>
                            <select id="enrichType">
                                <option value="both">Both</option>
                                <option value="mouldings">Mouldings Only</option>
                                <option value="mats">Mats Only</option>
                            </select>
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end;">
                            <button class="btn btn-primary" id="enrichBtn" onclick="startEnrichment()">Start Enrichment</button>
                            <span id="enrichStatus" style="margin-left:1rem; font-size:0.85rem; color:var(--text-secondary);"></span>
                        </div>
                    </div>
                </div>

                <!-- Browse Catalog -->
                <h3 style="color: var(--accent); margin: 1.5rem 0 1rem; font-family: 'Playfair Display', serif;">Browse Catalog</h3>

                <div style="margin-bottom: 1rem;">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Type</label>
                            <select id="browseType" onchange="browseCatalog(1)">
                                <option value="mouldings">Mouldings</option>
                                <option value="mats">Mats</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Vendor</label>
                            <input type="text" id="browseVendor" placeholder="e.g., Larson Juhl" />
                        </div>
                        <div class="form-group">
                            <label>Color</label>
                            <input type="text" id="browseColor" placeholder="e.g., Gold, Black" />
                        </div>
                        <div class="form-group">
                            <label>Style / Material</label>
                            <input type="text" id="browseStyle" placeholder="e.g., Traditional" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Finish Type</label>
                            <input type="text" id="browseFinish" placeholder="e.g., distressed, glossy" />
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end; gap:0.5rem;">
                            <button class="btn btn-primary" onclick="browseCatalog(1)">Search</button>
                            <button class="btn" style="background:var(--bg-secondary); color:var(--text-secondary); border:1px solid var(--border);" onclick="clearBrowse()">Clear</button>
                        </div>
                    </div>
                </div>

                <div id="browseInfo" style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:0.75rem;"></div>
                <div id="browseResults" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1rem;"></div>
                <div id="browsePagination" style="display:flex; justify-content:center; gap:0.5rem; margin-top:1.5rem;"></div>
            </div>

            <!-- === ART PRINTS === -->
            <div id="artprintsSection" class="section">
                <!-- Seed Art Prints -->
                <div class="add-form">
                    <h3>Seed Art Prints</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.85rem;">
                        Seeds built-in art print vendors and prints into the local database.
                        Clears and replaces all existing art print data.
                    </p>
                    <button class="btn btn-primary" id="seedArtPrintsBtn" onclick="seedArtPrints()">Seed Art Prints</button>
                    <span id="apSeedStatus" style="margin-left: 1rem; font-size: 0.85rem; color: var(--text-secondary);"></span>
                </div>

                <!-- Add Art Print Vendor -->
                <div class="add-form" style="margin-top: 1.5rem;">
                    <h3>Add Art Print Vendor</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.85rem;">
                        Add a new art print vendor. Use <code>{filename}</code> in the image path pattern as a placeholder.
                    </p>
                    <div class="form-row">
                        <div class="form-group"><label>Vendor Name</label><input type="text" id="apVendorName" placeholder="e.g., Wild Apple" /></div>
                        <div class="form-group"><label>Code</label><input type="text" id="apVendorCode" placeholder="e.g., WILDAPPLE" /></div>
                    </div>
                    <div class="form-row">
                        <div class="form-group"><label>Image Base URL</label><input type="text" id="apVendorBaseUrl" value="https://lifesaversoft.s3.amazonaws.com" /></div>
                        <div class="form-group"><label>Image Path Pattern</label><input type="text" id="apVendorPathPattern" placeholder="Art Print Images/Vendor Name/{filename}" /></div>
                    </div>
                    <div class="form-group"><label>Website (optional)</label><input type="text" id="apVendorWebsite" placeholder="https://..." /></div>
                    <button class="btn btn-primary" onclick="addArtPrintVendor()">Add Vendor</button>
                    <span id="apVendorStatus" style="margin-left: 1rem; font-size: 0.85rem; color: var(--text-secondary);"></span>
                </div>

                <!-- Vendor List -->
                <div class="add-form" style="margin-top: 1.5rem;">
                    <h3>Art Print Vendors</h3>
                    <div id="apVendorList" style="font-size: 0.85rem; color: var(--text-secondary);">Loading...</div>
                </div>

                <!-- Add Individual Art Print -->
                <div class="add-form" style="margin-top: 1.5rem;">
                    <h3>Add Art Print</h3>
                    <div class="form-row">
                        <div class="form-group"><label>Vendor</label><select id="apPrintVendor"><option value="">Select vendor...</option></select></div>
                        <div class="form-group"><label>Item Number</label><input type="text" id="apPrintItemNum" placeholder="e.g., 14321CF" /></div>
                    </div>
                    <div class="form-row">
                        <div class="form-group"><label>Title</label><input type="text" id="apPrintTitle" placeholder="Print title" /></div>
                        <div class="form-group"><label>Artist</label><input type="text" id="apPrintArtist" placeholder="Artist name" /></div>
                    </div>
                    <div class="form-row">
                        <div class="form-group"><label>Genre</label><input type="text" id="apPrintGenre" placeholder="e.g., Floral, Landscape" /></div>
                        <div class="form-group"><label>Style</label><input type="text" id="apPrintStyle" placeholder="e.g., Contemporary, Impressionist" /></div>
                    </div>
                    <div class="form-row">
                        <div class="form-group"><label>Medium</label><input type="text" id="apPrintMedium" placeholder="e.g., Acrylic, Oil" /></div>
                        <div class="form-group"><label>Category</label><input type="text" id="apPrintCategory" placeholder="e.g., Botanical, Nature" /></div>
                    </div>
                    <div class="form-row">
                        <div class="form-group"><label>Subject Matter</label><input type="text" id="apPrintSubject" placeholder="Brief description of subject" /></div>
                        <div class="form-group"><label>Orientation</label><select id="apPrintOrientation"><option value="">Auto</option><option>Portrait</option><option>Landscape</option><option>Square</option></select></div>
                    </div>
                    <button class="btn btn-primary" onclick="addArtPrint()">Add Print</button>
                    <span id="apPrintStatus" style="margin-left: 1rem; font-size: 0.85rem; color: var(--text-secondary);"></span>
                </div>

                <!-- Enrichment -->
                <div class="add-form" style="margin-top: 1.5rem;">
                    <h3>AI Art Print Enrichment</h3>
                    <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.85rem;">
                        Analyzes each art print image with AI to extract colors, mood, style, subject tags, and description.
                        ~$0.003 per image with GPT-4o-mini.
                    </p>
                    <div id="apEnrichProgress" style="margin-bottom: 1rem;">
                        <div style="display:flex; gap:2rem; font-size:0.85rem; color:var(--text-secondary); margin-bottom:0.5rem;">
                            <span>Art Prints: <span class="stat-value" id="apEnrichDone">0</span> / <span id="apEnrichTotal">0</span></span>
                        </div>
                        <div style="background:var(--bg-secondary); border-radius:4px; height:8px; overflow:hidden;">
                            <div id="apEnrichBar" style="background:var(--accent); height:100%; width:0%; transition:width 0.3s;"></div>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Batch Size</label>
                            <input type="number" id="apEnrichBatchSize" value="25" min="1" max="200" />
                        </div>
                        <div class="form-group">
                            <label>Vendor Filter (optional)</label>
                            <input type="text" id="apEnrichVendorFilter" placeholder="e.g., Wild Apple" />
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end;">
                            <button class="btn btn-primary" id="apEnrichBtn" onclick="startArtPrintEnrichment()">Start Enrichment</button>
                            <span id="apEnrichStatus" style="margin-left:1rem; font-size:0.85rem; color:var(--text-secondary);"></span>
                        </div>
                    </div>
                </div>

                <!-- Browse Art Prints -->
                <h3 style="color: var(--accent); margin: 1.5rem 0 1rem; font-family: 'Playfair Display', serif;">Browse Art Prints</h3>

                <div style="margin-bottom: 1rem;">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Search</label>
                            <input type="text" id="apQuery" placeholder="Title, artist, keyword..." />
                        </div>
                        <div class="form-group">
                            <label>Vendor</label>
                            <input type="text" id="apVendor" placeholder="e.g., Wild Apple" />
                        </div>
                        <div class="form-group">
                            <label>Artist</label>
                            <input type="text" id="apArtist" placeholder="e.g., Jane Doe" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Genre</label>
                            <input type="text" id="apGenre" placeholder="e.g., Landscape" />
                        </div>
                        <div class="form-group">
                            <label>Style</label>
                            <input type="text" id="apStyle" placeholder="e.g., Abstract" />
                        </div>
                        <div class="form-group">
                            <label>Mood</label>
                            <input type="text" id="apMood" placeholder="e.g., Serene" />
                        </div>
                        <div class="form-group" style="display:flex; align-items:flex-end; gap:0.5rem;">
                            <button class="btn btn-primary" onclick="browseArtPrints(1)">Search</button>
                            <button class="btn" style="background:var(--bg-secondary); color:var(--text-secondary); border:1px solid var(--border);" onclick="clearArtPrintBrowse()">Clear</button>
                        </div>
                    </div>
                </div>

                <div id="apBrowseInfo" style="font-size:0.85rem; color:var(--text-secondary); margin-bottom:0.75rem;"></div>
                <div id="apBrowseResults" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1rem;"></div>
                <div id="apBrowsePagination" style="display:flex; justify-content:center; gap:0.5rem; margin-top:1.5rem;"></div>
            </div>
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <script>
        let adminKey = '';

        // === Auth ===
        async function authenticate() {
            const key = document.getElementById('adminKeyInput').value;
            try {
                const res = await fetch('/Training/ValidateKey', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ key })
                });
                if (res.ok) {
                    adminKey = key;
                    document.getElementById('authGate').classList.add('hidden');
                    document.getElementById('adminUI').classList.remove('hidden');
                    loadAll();
                } else {
                    document.getElementById('authError').textContent = 'Invalid admin key.';
                    document.getElementById('authError').classList.remove('hidden');
                }
            } catch {
                document.getElementById('authError').textContent = 'Connection error.';
                document.getElementById('authError').classList.remove('hidden');
            }
        }

        document.getElementById('adminKeyInput').addEventListener('keypress', e => {
            if (e.key === 'Enter') authenticate();
        });

        // === Tabs ===
        function showTab(tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            document.querySelector(`[onclick="showTab('${tab}')"]`).classList.add('active');
            document.getElementById(`${tab}Section`).classList.add('active');
        }

        // === Toast ===
        function showToast(message) {
            const t = document.getElementById('toast');
            t.textContent = message;
            t.classList.add('show');
            setTimeout(() => t.classList.remove('show'), 3000);
        }

        // === Load All ===
        async function loadAll() {
            loadStats();
            loadCatalogStats();
            loadArtPrintStats();
            checkCatalogConnection();
            loadEnrichmentStatus();
            loadRules();
            loadStyleGuides();
            loadExamples();
            initComboboxes();
            loadArtPrintVendors();
        }

        async function loadStats() {
            try {
                const res = await fetch('/Training/Stats');
                const data = await res.json();
                document.getElementById('statRules').textContent = data.rules;
                document.getElementById('statGuides').textContent = data.styleGuides;
                document.getElementById('statExamples').textContent = data.trainingExamples;
                document.getElementById('statVendors').textContent = data.vendors;
            } catch {}
        }

        // === Rules ===
        async function loadRules() {
            try {
                const res = await fetch('/Training/GetRules');
                const rules = await res.json();
                const container = document.getElementById('rulesList');
                container.innerHTML = rules.map(r => `
                    <div class="card">
                        <div class="card-header">
                            <h3>${r.principle.substring(0, 80)}${r.principle.length > 80 ? '...' : ''}</h3>
                            <div class="card-actions">
                                <span class="badge">${r.category}</span>
                                <button class="btn btn-danger btn-small" onclick="deleteRule('${r.id}')">Delete</button>
                            </div>
                        </div>
                        <p>${r.principle}</p>
                        ${r.examples && r.examples.length > 0 ? `<ul class="examples-list">${r.examples.map(e => `<li>${e}</li>`).join('')}</ul>` : ''}
                        <p style="font-size:0.8rem; margin-top:0.5rem;">Confidence: ${r.confidence} | By: ${r.addedBy || 'Unknown'}</p>
                    </div>
                `).join('');
            } catch {}
        }

        async function addRule() {
            const rule = {
                category: document.getElementById('ruleCategory').value,
                principle: document.getElementById('rulePrinciple').value,
                examples: document.getElementById('ruleExample').value ? [document.getElementById('ruleExample').value] : [],
                addedBy: document.getElementById('ruleAddedBy').value,
                confidence: document.getElementById('ruleConfidence').value
            };
            if (!rule.principle) return;

            try {
                const res = await fetch('/Training/AddRule', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ adminKey, rule })
                });
                if (res.ok) {
                    showToast('Rule added successfully');
                    document.getElementById('rulePrinciple').value = '';
                    document.getElementById('ruleExample').value = '';
                    document.getElementById('ruleAddedBy').value = '';
                    loadRules();
                    loadStats();
                }
            } catch {}
        }

        async function deleteRule(id) {
            if (!confirm('Delete this rule?')) return;
            try {
                const res = await fetch('/Training/DeleteRule', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ adminKey, id })
                });
                if (res.ok) {
                    showToast('Rule deleted');
                    loadRules();
                    loadStats();
                }
            } catch {}
        }

        // === Style Guides ===
        async function loadStyleGuides() {
            try {
                const res = await fetch('/Training/GetStyleGuides');
                const guides = await res.json();
                const container = document.getElementById('guidesList');
                container.innerHTML = guides.map(g => `
                    <div class="card">
                        <div class="card-header">
                            <h3>${g.artStyle}</h3>
                            <div class="card-actions">
                                <button class="btn btn-danger btn-small" onclick="deleteStyleGuide('${g.artStyle}')">Delete</button>
                            </div>
                        </div>
                        <p><strong>Preferred:</strong> ${(g.preferredMouldings || []).join(', ')}</p>
                        <p><strong>Avoid:</strong> ${(g.avoidMouldings || []).join(', ')}</p>
                        <p><strong>Mat:</strong> ${g.matGuidance}</p>
                        <p><strong>Width:</strong> ${g.widthGuidance}</p>
                        ${g.notes ? `<p><strong>Notes:</strong> ${g.notes}</p>` : ''}
                    </div>
                `).join('');
            } catch {}
        }

        async function addStyleGuide() {
            const guide = {
                artStyle: document.getElementById('guideArtStyle').value,
                keywords: document.getElementById('guideKeywords').value.split(',').map(s => s.trim()).filter(Boolean),
                preferredMouldings: document.getElementById('guidePreferred').value.split(',').map(s => s.trim()).filter(Boolean),
                avoidMouldings: document.getElementById('guideAvoid').value.split(',').map(s => s.trim()).filter(Boolean),
                matGuidance: document.getElementById('guideMatGuidance').value,
                widthGuidance: document.getElementById('guideWidthGuidance').value,
                notes: document.getElementById('guideNotes').value
            };
            if (!guide.artStyle) return;

            try {
                const res = await fetch('/Training/AddStyleGuide', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ adminKey, guide })
                });
                if (res.ok) {
                    showToast('Style guide added');
                    document.getElementById('guideArtStyle').value = '';
                    document.getElementById('guideKeywords').value = '';
                    document.getElementById('guidePreferred').value = '';
                    document.getElementById('guideAvoid').value = '';
                    document.getElementById('guideMatGuidance').value = '';
                    document.getElementById('guideWidthGuidance').value = '';
                    document.getElementById('guideNotes').value = '';
                    loadStyleGuides();
                    loadStats();
                }
            } catch {}
        }

        async function deleteStyleGuide(artStyle) {
            if (!confirm('Delete this style guide?')) return;
            try {
                const res = await fetch('/Training/DeleteStyleGuide', {
                    method: 'POST',
