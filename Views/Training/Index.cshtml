                }
                list.innerHTML = '<table style="width:100%; border-collapse:collapse;">' +
                    '<tr style="border-bottom:1px solid var(--border); color:var(--accent); font-size:0.8rem;">' +
                    '<th style="text-align:left; padding:0.4rem;">Name</th><th style="text-align:left; padding:0.4rem;">Code</th>' +
                    '<th style="text-align:left; padding:0.4rem;">S3 Path</th><th style="text-align:left; padding:0.4rem;">Active</th></tr>' +
                    vendors.map(v => '<tr style="border-bottom:1px solid var(--bg-secondary);">' +
                        '<td style="padding:0.4rem;">' + v.name + '</td>' +
                        '<td style="padding:0.4rem; color:var(--text-secondary);">' + v.code + '</td>' +
                        '<td style="padding:0.4rem; color:var(--text-secondary); font-size:0.8rem;">' + (v.imagePathPattern || '-') + '</td>' +
                        '<td style="padding:0.4rem;">' + (v.isActive ? '&#x2713;' : '&#x2717;') + '</td></tr>').join('') +
                    '</table>';
                // Populate vendor select for add print form
                select.innerHTML = '<option value="">Select vendor...</option>' +
                    vendors.map(v => '<option value="' + v.id + '" data-name="' + v.name + '">' + v.name + ' (' + v.code + ')</option>').join('');
            } catch {}
        }

        async function addArtPrintVendor() {
            const status = document.getElementById('apVendorStatus');
            const data = {
                adminKey,
                name: document.getElementById('apVendorName').value,
                code: document.getElementById('apVendorCode').value,
                imageBaseUrl: document.getElementById('apVendorBaseUrl').value,
                imagePathPattern: document.getElementById('apVendorPathPattern').value,
                website: document.getElementById('apVendorWebsite').value
            };
            if (!data.name || !data.code) { status.textContent = 'Name and code are required.'; status.style.color = 'var(--danger)'; return; }
            try {
                const res = await fetch('/Training/AddArtPrintVendor', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    showToast('Vendor added: ' + data.name);
                    status.textContent = 'Added!';
                    status.style.color = 'var(--success)';
                    document.getElementById('apVendorName').value = '';
                    document.getElementById('apVendorCode').value = '';
                    document.getElementById('apVendorPathPattern').value = '';
                    document.getElementById('apVendorWebsite').value = '';
                    loadArtPrintVendors();
                } else {
                    status.textContent = result.error || 'Failed';
                    status.style.color = 'var(--danger)';
                }
            } catch (e) { status.textContent = e.message; status.style.color = 'var(--danger)'; }
        }

        async function addArtPrint() {
            const status = document.getElementById('apPrintStatus');
            const vendorSelect = document.getElementById('apPrintVendor');
            const vendorId = parseInt(vendorSelect.value);
            const vendorName = vendorSelect.selectedOptions[0]?.dataset?.name || '';
            if (!vendorId) { status.textContent = 'Select a vendor.'; status.style.color = 'var(--danger)'; return; }
            const data = {
                adminKey, vendorId, vendorName,
                itemNumber: document.getElementById('apPrintItemNum').value,
                title: document.getElementById('apPrintTitle').value,
                artist: document.getElementById('apPrintArtist').value,
                genre: document.getElementById('apPrintGenre').value,
                style: document.getElementById('apPrintStyle').value,
                medium: document.getElementById('apPrintMedium').value,
                category: document.getElementById('apPrintCategory').value,
                subjectMatter: document.getElementById('apPrintSubject').value,
                orientation: document.getElementById('apPrintOrientation').value
            };
            if (!data.itemNumber || !data.title) { status.textContent = 'Item number and title are required.'; status.style.color = 'var(--danger)'; return; }
            try {
                const res = await fetch('/Training/AddArtPrint', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    showToast('Print added: ' + data.title);
                    status.textContent = 'Added!';
                    status.style.color = 'var(--success)';
                    ['apPrintItemNum','apPrintTitle','apPrintArtist','apPrintGenre','apPrintStyle','apPrintMedium','apPrintCategory','apPrintSubject'].forEach(id => document.getElementById(id).value = '');
                    loadArtPrintStats();
                } else {
                    status.textContent = result.error || 'Failed';
                    status.style.color = 'var(--danger)';
                }
            } catch (e) { status.textContent = e.message; status.style.color = 'var(--danger)'; }
        }

        async function startArtPrintEnrichment() {
            const btn = document.getElementById('apEnrichBtn');
            const status = document.getElementById('apEnrichStatus');
            btn.disabled = true;
            btn.textContent = 'Enriching...';
            status.textContent = 'Analyzing art print images with AI...';

            try {
                const res = await fetch('/Training/EnrichArtPrints', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        adminKey,
                        batchSize: parseInt(document.getElementById('apEnrichBatchSize').value) || 25,
                        vendorFilter: document.getElementById('apEnrichVendorFilter').value || null
                    })
                });
                const result = await res.json();
                showToast(`Enriched ${result.analyzed} prints (${result.skipped} skipped, ${result.remaining} remaining)`);
                status.textContent = `Done: ${result.analyzed} analyzed, ${result.remaining} remaining`;
                loadEnrichmentStatus();
                loadArtPrintStats();
            } catch (e) {
                status.textContent = `Error: ${e.message}`;
                status.style.color = 'var(--danger)';
            } finally {
                btn.disabled = false;
                btn.textContent = 'Start Enrichment';
            }
        }

        // === Browse Art Prints ===
        async function browseArtPrints(page) {
            const params = new URLSearchParams();
            const q = document.getElementById('apQuery').value;
            const vendor = document.getElementById('apVendor').value;
            const artist = document.getElementById('apArtist').value;
            const genre = document.getElementById('apGenre').value;
            const style = document.getElementById('apStyle').value;
            const mood = document.getElementById('apMood').value;

            if (q) params.set('query', q);
            if (vendor) params.set('vendor', vendor);
            if (artist) params.set('artist', artist);
            if (genre) params.set('genre', genre);
            if (style) params.set('style', style);
            if (mood) params.set('mood', mood);
            params.set('page', page);
            params.set('pageSize', 24);

            try {
                const res = await fetch(`/Training/BrowseArtPrints?${params}`);
                const data = await res.json();

                document.getElementById('apBrowseInfo').textContent =
                    `Showing ${data.prints.length} of ${data.totalCount} prints (page ${data.page}/${data.totalPages})`;

                const container = document.getElementById('apBrowseResults');
                container.innerHTML = '';

                for (const p of data.prints) {
                    const card = document.createElement('div');
                    card.className = 'catalog-card';
                    card.style.cssText = 'background:var(--bg-card); border:1px solid var(--border); border-radius:8px; overflow:hidden; cursor:pointer;';

                    const imgHtml = p.imageUrl
                        ? `<div style="height:180px; overflow:hidden; background:var(--bg-secondary);"><img src="${p.imageUrl}" alt="${p.title}" style="width:100%; height:100%; object-fit:cover;" loading="lazy" onerror="this.parentElement.innerHTML='<div style=\\'display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-secondary);font-size:0.8rem;\\'>No Image</div>';" /></div>`
                        : `<div style="height:180px; display:flex; align-items:center; justify-content:center; background:var(--bg-secondary); color:var(--text-secondary); font-size:0.8rem;">No Image</div>`;

                    const colorsHtml = p.primaryColorHex
                        ? `<div style="display:flex; gap:4px; margin-top:4px;">${[p.primaryColorHex, p.secondaryColorHex, p.tertiaryColorHex].filter(Boolean).map(c => `<span style="width:14px;height:14px;border-radius:50%;background:${c};border:1px solid var(--border);display:inline-block;" title="${c}"></span>`).join('')}</div>`
                        : '';

                    const moodBadge = p.aiMood ? `<span style="display:inline-block;padding:2px 6px;border-radius:4px;font-size:0.7rem;background:var(--bg-secondary);color:var(--accent);border:1px solid var(--border);">${p.aiMood}</span>` : '';
                    const styleBadge = p.aiStyle ? `<span style="display:inline-block;padding:2px 6px;border-radius:4px;font-size:0.7rem;background:var(--bg-secondary);color:var(--text-secondary);border:1px solid var(--border);">${p.aiStyle}</span>` : '';

                    card.innerHTML = `
                        ${imgHtml}
                        <div style="padding:0.75rem;">
                            <div style="font-weight:500; font-size:0.85rem; margin-bottom:2px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${p.title}</div>
                            <div style="font-size:0.75rem; color:var(--text-secondary); margin-bottom:4px;">${p.artist || 'Unknown Artist'} &middot; ${p.vendorName}</div>
                            <div style="display:flex; gap:4px; flex-wrap:wrap; align-items:center;">${moodBadge}${styleBadge}${colorsHtml}</div>
                            ${p.genre ? `<div style="font-size:0.7rem; color:var(--text-secondary); margin-top:4px;">${p.genre}${p.orientation ? ' &middot; ' + p.orientation : ''}</div>` : ''}
                        </div>`;

                    container.appendChild(card);
                }

                // Pagination
                const pagDiv = document.getElementById('apBrowsePagination');
                let btns = '';
                if (data.totalPages > 1) {
                    if (data.page > 1) btns += `<button class="page-btn" onclick="browseArtPrints(${data.page - 1})">Prev</button>`;
                    for (let i = Math.max(1, data.page - 2); i <= Math.min(data.totalPages, data.page + 2); i++) {
                        btns += `<button class="page-btn ${i === data.page ? 'active' : ''}" onclick="browseArtPrints(${i})">${i}</button>`;
                    }
                    if (data.page < data.totalPages) btns += `<button class="page-btn" onclick="browseArtPrints(${data.page + 1})">Next</button>`;
                }
                pagDiv.innerHTML = btns;
            } catch (e) {
                document.getElementById('apBrowseInfo').textContent = `Error: ${e.message}`;
            }
        }

        function clearArtPrintBrowse() {
            ['apQuery','apVendor','apArtist','apGenre','apStyle','apMood'].forEach(id => document.getElementById(id).value = '');
            document.getElementById('apBrowseResults').innerHTML = '';
            document.getElementById('apBrowsePagination').innerHTML = '';
            document.getElementById('apBrowseInfo').textContent = '';
        }

        // Initialize voice input on page load
        initVoiceInput();
    </script>
</body>
</html>
