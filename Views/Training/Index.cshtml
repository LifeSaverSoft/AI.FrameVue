        async function browseCatalog(page) {
            currentBrowsePage = page || 1;
            const type = document.getElementById('browseType').value;
            const params = new URLSearchParams();
            const vendor = document.getElementById('browseVendor').value;
            const color = document.getElementById('browseColor').value;
            const style = document.getElementById('browseStyle').value;
            const finish = document.getElementById('browseFinish').value;

            if (vendor) params.set('vendor', vendor);
            if (color) params.set('color', color);
            if (finish) params.set('finish', finish);
            if (type === 'mouldings' && style) params.set('style', style);
            if (type === 'mats' && style) params.set('material', style);
            params.set('page', currentBrowsePage);
            params.set('pageSize', '24');

            const endpoint = type === 'mouldings' ? 'BrowseMouldings' : 'BrowseMats';

            try {
                const res = await fetch(`/Training/${endpoint}?${params}`);
                const data = await res.json();

                document.getElementById('browseInfo').textContent =
                    `Showing ${(data.page - 1) * data.pageSize + 1}–${Math.min(data.page * data.pageSize, data.total)} of ${data.total} ${type}`;

                const container = document.getElementById('browseResults');
                if (data.items.length === 0) {
                    container.innerHTML = '<p style="color:var(--text-secondary); grid-column:1/-1;">No results found.</p>';
                    document.getElementById('browsePagination').innerHTML = '';
                    return;
                }

                container.innerHTML = data.items.map(item => {
                    const colorSwatch = item.primaryColorHex
                        ? `<span class="color-swatch" style="background:${item.primaryColorHex}"></span>${item.primaryColorName || item.primaryColorHex}`
                        : item.colorCategory || 'Unknown';
                    const secondarySwatch = item.secondaryColorHex
                        ? ` / <span class="color-swatch" style="background:${item.secondaryColorHex}"></span>${item.secondaryColorName || ''}`
                        : '';
                    const finishInfo = item.finishType ? ` | ${item.finishType}` : '';
                    const tempInfo = item.colorTemperature ? ` | ${item.colorTemperature}` : '';

                    const details = type === 'mouldings'
                        ? `${item.style || ''} | ${item.profile || ''} | ${item.mouldingWidth}"`
                        : `${item.matClass || ''} | ${item.material || ''}`;

                    return `
                        <div class="product-card">
                            <img src="${item.imageUrl || ''}" alt="${item.itemName}" onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 200 160%22><rect fill=%22%23141422%22 width=%22200%22 height=%22160%22/><text fill=%22%238888a0%22 x=%2250%%22 y=%2250%%22 text-anchor=%22middle%22 font-size=%2212%22>No Image</text></svg>'" />
                            <div class="card-body">
                                <h4>${item.itemName}</h4>
                                <p><span class="badge" style="margin-right:4px;">${item.vendorName}</span></p>
                                <p>${colorSwatch}${secondarySwatch}${finishInfo}${tempInfo}</p>
                                <p>${details}</p>
                                ${item.imageAnalyzedAt ? '<p style="color:var(--success); font-size:0.7rem;">AI Analyzed</p>' : ''}
                            </div>
                        </div>`;
                }).join('');

                // Pagination
                const pagination = document.getElementById('browsePagination');
                if (data.totalPages > 1) {
                    let btns = '';
                    if (data.page > 1) btns += `<button class="page-btn" onclick="browseCatalog(${data.page - 1})">Prev</button>`;
                    const start = Math.max(1, data.page - 3);
                    const end = Math.min(data.totalPages, data.page + 3);
                    for (let i = start; i <= end; i++) {
                        btns += `<button class="page-btn ${i === data.page ? 'active' : ''}" onclick="browseCatalog(${i})">${i}</button>`;
                    }
                    if (data.page < data.totalPages) btns += `<button class="page-btn" onclick="browseCatalog(${data.page + 1})">Next</button>`;
                    pagination.innerHTML = btns;
                } else {
                    pagination.innerHTML = '';
                }
            } catch (e) {
                document.getElementById('browseResults').innerHTML = `<p style="color:var(--danger);">Error: ${e.message}</p>`;
            }
        }
        // === Voice Dictation ===
        let recognition = null;
        let activeFieldId = null;

        function initVoiceInput() {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SpeechRecognition) {
                // Hide all mic buttons — browser doesn't support speech
                document.body.classList.add('no-speech-api');
                return;
            }

            recognition = new SpeechRecognition();
            recognition.continuous = false;
            recognition.interimResults = true;
            recognition.lang = 'en-US';

            recognition.onresult = function(event) {
                if (!activeFieldId) return;
                const field = document.getElementById(activeFieldId);
                if (!field) return;

                let finalTranscript = '';
                let interimTranscript = '';

                for (let i = event.resultIndex; i < event.results.length; i++) {
                    const transcript = event.results[i][0].transcript;
                    if (event.results[i].isFinal) {
                        finalTranscript += transcript;
                    } else {
                        interimTranscript += transcript;
                    }
                }

                if (finalTranscript) {
                    const isTextarea = field.tagName === 'TEXTAREA';
                    if (isTextarea && field.value.trim()) {
                        // Append to existing content for textareas
                        field.value = field.value.trimEnd() + ' ' + finalTranscript;
                    } else {
                        field.value = finalTranscript;
                    }
                }
            };

            recognition.onend = function() {
                if (activeFieldId) {
                    const btn = document.getElementById('mic-' + activeFieldId);
                    if (btn) btn.classList.remove('recording');
                }
                activeFieldId = null;
            };

            recognition.onerror = function(event) {
                if (event.error === 'not-allowed') {
                    showToast('Microphone access denied. Please allow microphone in browser settings.');
                } else if (event.error !== 'aborted' && event.error !== 'no-speech') {
                    showToast('Voice input error: ' + event.error);
                }
                if (activeFieldId) {
                    const btn = document.getElementById('mic-' + activeFieldId);
                    if (btn) btn.classList.remove('recording');
                }
                activeFieldId = null;
            };
        }

        function toggleRecording(fieldId) {
            if (!recognition) return;

            // If already recording this field, stop
            if (activeFieldId === fieldId) {
                recognition.stop();
                return;
            }

            // If recording a different field, stop that first
            if (activeFieldId) {
                recognition.stop();
                const prevBtn = document.getElementById('mic-' + activeFieldId);
                if (prevBtn) prevBtn.classList.remove('recording');
            }

            // Start recording for the new field
            activeFieldId = fieldId;
            const btn = document.getElementById('mic-' + fieldId);
            if (btn) btn.classList.add('recording');

            try {
                recognition.start();
            } catch (e) {
                // Already started — ignore
            }
        }

        // === Combobox Class ===
        class Combobox {
            constructor(inputId, options) {
                this.input = document.getElementById(inputId);
                if (!this.input) return;
                this.options = options || [];
                this.filtered = [];
                this.highlightIdx = -1;

                // Wrap input in .combobox container
                const wrapper = document.createElement('div');
                wrapper.className = 'combobox';
                this.input.parentNode.insertBefore(wrapper, this.input);
                wrapper.appendChild(this.input);

                // Chevron SVG
                const chevron = document.createElement('span');
                chevron.className = 'combobox-chevron';
                chevron.innerHTML = '<svg viewBox="0 0 14 14" fill="none" width="14" height="14"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>';
                wrapper.appendChild(chevron);

                // Dropdown list
                this.dropdown = document.createElement('ul');
                this.dropdown.className = 'combobox-dropdown';
                this.dropdown.setAttribute('role', 'listbox');
                wrapper.appendChild(this.dropdown);

                this.input.setAttribute('role', 'combobox');
                this.input.setAttribute('aria-expanded', 'false');
                this.input.setAttribute('aria-autocomplete', 'list');
                this.input.setAttribute('autocomplete', 'off');
                this.wrapper = wrapper;

                this.input.addEventListener('input', () => this.onInput());
                this.input.addEventListener('focus', () => this.open());
                this.input.addEventListener('keydown', (e) => this.onKeyDown(e));
                document.addEventListener('click', (e) => {
                    if (!wrapper.contains(e.target)) this.close();
                });
            }

            setOptions(options) {
                this.options = options || [];
                if (this.wrapper.classList.contains('open')) this.onInput();
            }

            onInput() {
                const val = this.input.value.toLowerCase();
                if (!val) {
                    this.filtered = this.options.slice(0, 50);
                } else {
                    const startsWith = this.options.filter(o => o.toLowerCase().startsWith(val));
                    const contains = this.options.filter(o => !o.toLowerCase().startsWith(val) && o.toLowerCase().includes(val));
                    this.filtered = startsWith.concat(contains).slice(0, 50);
                }
                this.highlightIdx = -1;
                this.render();
                this.open();
            }

            render() {
                const val = this.input.value.toLowerCase();
                this.dropdown.innerHTML = this.filtered.map((opt, i) => {
                    const cls = i === this.highlightIdx ? ' class="highlighted"' : '';
                    const display = val ? this.highlightMatch(opt, val) : this.esc(opt);
                    return `<li${cls} role="option" data-index="${i}">${display}</li>`;
                }).join('');

                this.dropdown.querySelectorAll('li').forEach(li => {
                    li.addEventListener('mousedown', (e) => {
                        e.preventDefault();
                        this.select(parseInt(li.dataset.index));
                    });
                });
            }

            highlightMatch(text, query) {
                const idx = text.toLowerCase().indexOf(query);
                if (idx < 0) return this.esc(text);
                return this.esc(text.substring(0, idx)) +
                    '<span class="match">' + this.esc(text.substring(idx, idx + query.length)) + '</span>' +
                    this.esc(text.substring(idx + query.length));
            }

            esc(str) {
                const d = document.createElement('div');
                d.textContent = str;
                return d.innerHTML;
            }

            select(idx) {
                if (idx >= 0 && idx < this.filtered.length) {
                    this.input.value = this.filtered[idx];
                    this.input.dispatchEvent(new Event('input', { bubbles: true }));
                }
                this.close();
            }

            open() {
                if (!this.filtered.length && !this.input.value) {
                    this.filtered = this.options.slice(0, 50);
                    this.render();
                }
                if (!this.filtered.length) return;
                this.wrapper.classList.add('open');
                this.input.setAttribute('aria-expanded', 'true');
            }

            close() {
                this.wrapper.classList.remove('open');
                this.input.setAttribute('aria-expanded', 'false');
                this.highlightIdx = -1;
            }

            onKeyDown(e) {
                if (!this.wrapper.classList.contains('open')) {
                    if (e.key === 'ArrowDown') { this.open(); e.preventDefault(); }
                    return;
                }
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    this.highlightIdx = Math.min(this.highlightIdx + 1, this.filtered.length - 1);
                    this.render();
                    this.scrollToHighlighted();
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    this.highlightIdx = Math.max(this.highlightIdx - 1, 0);
                    this.render();
                    this.scrollToHighlighted();
                } else if (e.key === 'Enter') {
                    e.preventDefault();
                    if (this.highlightIdx >= 0) this.select(this.highlightIdx);
                    else this.close();
                } else if (e.key === 'Escape') {
                    this.close();
                }
            }

            scrollToHighlighted() {
                const el = this.dropdown.querySelector('.highlighted');
                if (el) el.scrollIntoView({ block: 'nearest' });
            }
        }

        // === Combobox Initialization ===
        const comboboxInstances = {};
        const filterOptionsCache = {};

        async function initComboboxes() {
            const type = document.getElementById('browseType')?.value || 'mouldings';
            const options = await fetchFilterOptions(type);
            if (!options) return;

            comboboxInstances.browseVendor = new Combobox('browseVendor', options.vendors);
            comboboxInstances.browseColor = new Combobox('browseColor', options.colors);
            comboboxInstances.browseStyle = new Combobox('browseStyle', options.styles.length ? options.styles : options.materials);
            comboboxInstances.browseFinish = new Combobox('browseFinish', options.finishes);

            // Enrichment vendor filter uses 'all' type
            const allOptions = await fetchFilterOptions('all');
            if (allOptions) {
                comboboxInstances.enrichVendorFilter = new Combobox('enrichVendorFilter', allOptions.vendors);
            }
        }

        async function fetchFilterOptions(type) {
            if (filterOptionsCache[type]) return filterOptionsCache[type];
            try {
                const res = await fetch(`/Training/CatalogFilterOptions?type=${type}`);
                if (!res.ok) return null;
                const data = await res.json();
                filterOptionsCache[type] = data;
                return data;
            } catch (e) {
                console.warn('Failed to fetch filter options:', e);
                return null;
            }
        }

        async function updateBrowseComboboxOptions() {
            const type = document.getElementById('browseType')?.value || 'mouldings';
            const options = await fetchFilterOptions(type);
            if (!options) return;

            if (comboboxInstances.browseVendor) comboboxInstances.browseVendor.setOptions(options.vendors);
            if (comboboxInstances.browseColor) comboboxInstances.browseColor.setOptions(options.colors);
            if (comboboxInstances.browseStyle) comboboxInstances.browseStyle.setOptions(options.styles.length ? options.styles : options.materials);
            if (comboboxInstances.browseFinish) comboboxInstances.browseFinish.setOptions(options.finishes);

            // Update label for Style/Material
            const styleLabel = document.querySelector('#browseStyle')?.closest('.form-group')?.querySelector('label');
            if (styleLabel) {
                styleLabel.textContent = type === 'mats' ? 'Material' : 'Style / Material';
            }
        }

        function invalidateFilterOptionsCache() {
            Object.keys(filterOptionsCache).forEach(k => delete filterOptionsCache[k]);
        }

        // Hook: browseType change triggers combobox option update
        document.getElementById('browseType')?.addEventListener('change', updateBrowseComboboxOptions);

