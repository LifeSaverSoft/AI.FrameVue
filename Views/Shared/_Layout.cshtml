<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI.FrameVue — AI-Powered Custom Framing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect x='2' y='2' width='28' height='28' rx='3' fill='none' stroke='%23c9a84c' stroke-width='2.5'/><rect x='6' y='6' width='20' height='20' rx='1' fill='none' stroke='%23c9a84c' stroke-width='1' opacity='0.6'/></svg>" />
</head>
<body>
    <header class="site-header">
        <div class="header-inner">
            <a href="/" class="brand">
                <span class="brand-icon">
                    <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="2" width="32" height="32" rx="3" stroke="currentColor" stroke-width="2"/>
                        <rect x="6" y="6" width="24" height="24" rx="1.5" stroke="currentColor" stroke-width="1" opacity="0.5"/>
                        <rect x="10" y="10" width="16" height="16" rx="1" fill="currentColor" opacity="0.1"/>
                    </svg>
                </span>
                <span class="brand-text">
                    <span class="brand-ai">AI</span><span class="brand-dot">.</span><span class="brand-name">FrameVue</span>
                </span>
            </a>
            <span class="tagline">AI-Powered Custom Framing</span>
        </div>
    </header>

    <main class="site-main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <span class="footer-brand">AI.FrameVue</span>
            <span class="footer-divider">|</span>
            <span>Proof of Concept</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.170.0/examples/js/controls/OrbitControls.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
